{
  "name": "shop-motion",
  "version": "1.0.0",
  "description": "ShopMotion：基于 React、TypeScript、Node.js 与 Remotion 的电商带货短视频自动生成系统 - v1 模板系统增强版",
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch src/modules/server/index.ts",
    "dev:frontend": "vite",
    "dev:remotion": "remotion studio src/modules/remotion/compositions/index.tsx",
    "build": "tsc && vite build",
    "start": "node dist/modules/server/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0",
    "@remotion/cli": "^4.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.0"
  }
}
