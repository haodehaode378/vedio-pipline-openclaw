# ============================================
# ShopMotion 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================

# --- 后端服务 ---
PORT=3001
NODE_ENV=development

# --- 飞书通知 (可选) ---
# 飞书机器人 Webhook 地址，不配置则跳过通知
FEISHU_WEBHOOK_URL=

# --- LLM Provider (可选, 当前使用 mock) ---
# 未来接入真实 LLM 时配置
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=

# --- TTS Provider (可选, 当前使用 mock) ---
# 未来接入真实 TTS 时配置
# MINIMAX_API_KEY=

# --- 前端 (Vite) ---
# 后端 API 地址，默认 http://localhost:3001/api
# VITE_API_BASE=http://localhost:3001/api
